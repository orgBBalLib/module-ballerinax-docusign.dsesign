public type OfflineAttributes record {
    # Reserved for Docusign
    string gpsLongitude?;
    # Reserved for Docusign
    string accountEsignId?;
    # Reserved for Docusign
    string offlineSigningHash?;
    # Reserved for Docusign
    string deviceModel?;
    # Reserved for Docusign
    string deviceName?;
    # Reserved for Docusign
    string gpsLatitude?;
