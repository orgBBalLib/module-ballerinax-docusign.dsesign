    string[] tabGroupLabels?;
    # Metadata about a property
    PropertyMetadata toolTipMetadata?;
    # Metadata about a property
    PropertyMetadata anchorStringMetadata?;
    # Metadata about a property
    PropertyMetadata formPageLabelMetadata?;
    # Metadata about a property
