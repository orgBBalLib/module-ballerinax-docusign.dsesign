    # - `lastfirst_cjk`<br>GatesWilliam only with CJK characters
    # 
    # <!-- Web/RestApi/Models/v2_1/localePolicy.cs#L341-L366 -->
    string nameFormat?;
    # Specifies the time format. Valid values:
    # 
    # - `none`      <br>None
    # - `hh_mm`     <br>hh:mm 
    # - `hhmm`      <br>HH:mm
    # - `hhmmss`    <br>HH:mm:ss
    # - `hhmmsstt`  <br>HH:mm:ss tt
