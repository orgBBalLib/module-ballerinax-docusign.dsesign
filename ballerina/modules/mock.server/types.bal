    string recipientId?;
    # Metadata about a property
    PropertyMetadata xPositionMetadata?;
    # Metadata about a property
    PropertyMetadata tabGroupLabelsMetadata?;
    # Specifies units of the `anchorXOffset` and `anchorYOffset`. Valid units are:
    # 
    # - `pixels` (default)
    # - `inches`
    # - `mms`
    # - `cms`
    string anchorUnits?;
    # Metadata about a property
