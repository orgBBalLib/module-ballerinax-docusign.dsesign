    # Metadata about a property
    PropertyMetadata tabTypeMetadata?;
    # Metadata about a property
    PropertyMetadata anchorAllowWhiteSpaceInCharactersMetadata?;
    # Metadata about a property
    PropertyMetadata anchorIgnoreIfNotPresentMetadata?;
    # The height of the tab in pixels.
